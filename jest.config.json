{
  "preset": "ts-jest",
  "testEnvironment": "node",
  "exportConditions": ["node", "import"],
  "moduleDirectories": ["node_modules", "../node_modules"],
  "moduleNameMapper": {
    "^@midnight-ntwrk/onchain-runtime-v3$": "<rootDir>/../node_modules/@midnight-ntwrk/onchain-runtime-v3/midnight_onchain_runtime_wasm_fs.js"
  },
  "roots": ["<rootDir>/src"],
  "testMatch": ["**/__tests__/**/*.ts", "**/?(*.)+(spec|test).ts"],
  "moduleFileExtensions": ["ts", "js", "json"],
  "setupFiles": ["<rootDir>/jest.setup.js"],
  "collectCoverageFrom": [
    "src/**/*.ts",
    "!src/**/*.d.ts",
    "!src/**/__tests__/**"
  ],
  "coverageThreshold": {
    "global": {
      "branches": 70,
      "functions": 70,
      "lines": 80,
      "statements": 80
    }
  }
}
